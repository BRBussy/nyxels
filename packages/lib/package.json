{
  "name": "@nyxels/lib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Environment-neutral shared code for Nyxels — network/config definitions, seed parsing and wallet derivation. Must run in both the browser (ui) and Node (integration-tests): no window, fs or process access.",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnight-ntwrk/midnight-js": "^4.1.1",
    "@midnight-ntwrk/wallet-sdk-abstractions": "^2.1.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.1.2",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^4.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^4.0.1",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.2",
    "@midnight-ntwrk/wallet-sdk-shielded": "^3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^3.1.0",
    "@scure/bip39": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
